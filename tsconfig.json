{
	"compilerOptions": {
		"target": "esnext",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"rootDir": "lib",
		"declaration": true,
		"strictNullChecks": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"lib": [
			"es2018"
		],
		"paths": {
			"*": ["./*"],
		},
		"types": [
			"node"
		]
	},
	"include": [
		"lib/**/*.ts",
	]
}
